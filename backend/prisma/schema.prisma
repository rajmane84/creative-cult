// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------- Enums -----------------------------------

enum CultMemberRole {
  LEADER
  MEMBER
}

enum CultMembershipStatus {
  ACTIVE
  LEFT
  REMOVED // kicked by a leader — kept distinct from LEFT for history/disputes
}

enum CultInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED  // leader cancelled it before response
  EXPIRED
}

enum Role {
  ADMIN
  CLIENT
  CREATIVE
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  NOT_AVAILABLE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  FREELANCE
  SELF_EMPLOYED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum Degree {
  HIGH_SCHOOL
  DIPLOMA
  BSC
  BCA
  BCOM
  BA
  BTECH
  BE
  BPHARM
  LLB
  MBBS
  MSC
  MCA
  MCOM
  MA
  MTECH
  ME
  MBA
  MPHARM
  LLM
  MD
  PHD
  OTHER
}

enum JoinAs {
  FREELANCER
  COLLECTIVE
  CLIENT
}


// ---------------------- Schemas -----------------------------

model User {
  id              String           @id
  name            String
  email           String
  emailVerified   Boolean          @default(false)
  image           String?
  role            Role?
  username        String?          @unique
  creativeProfile CreativeProfile?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sessions        Session[]
  accounts        Account[]

  cultsCreated Cult[]
  cultInvitesSent CultInvite[] @relation("CultInvitesSent")

  @@unique([email])
  @@map("user")
}

model CreativeProfile {
  id     String @id @default(cuid())
  headline            String?
  bio                 String?
  location            String? // We're not allowing the users to manually change the location
  availability        AvailabilityStatus @default(AVAILABLE)
  onboardingCompleted Boolean            @default(false)

  resumeUrl        String?
  resumeFileName   String?
  resumeUploadedAt DateTime?

  skills         CreativeSkill[]
  experiences    Experience[]
  education      Education[]
  // applications  Application[]    // applying to client projects

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cultMemberships CultMembership[]
  cultInvites     CultInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreativeSkill {
  id                String          @id @default(cuid())
  name              String
  level             SkillLevel?

  skillId           String
  skill             Skill           @relation(fields: [skillId], references: [id])

  creativeProfileId String
  creativeProfile   CreativeProfile @relation(fields: [creativeProfileId], references: [id], onDelete: Cascade)
  @@unique([creativeProfileId, skillId])
}

model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique

  creativeSkills CreativeSkill[]
  createdAt      DateTime @default(now())
}

model Cult {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique // for public cult profile URL, e.g. /cults/pixel-punks
  tagline  String?
  bio      String?
  avatarUrl String?

  createdByUserId String
  createdBy       User   @relation(fields: [createdByUserId], references: [id])

  memberships CultMembership[]
  invites     CultInvite[]
  // applications Application[]  // add once client-contacts-cult flow is built

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CultMembership {
  id     String                @id @default(cuid())
  role   CultMemberRole        @default(MEMBER)
  status CultMembershipStatus  @default(ACTIVE)

  cultId String
  cult   Cult   @relation(fields: [cultId], references: [id], onDelete: Cascade)

  creativeProfileId String
  creativeProfile   CreativeProfile @relation(fields: [creativeProfileId], references: [id], onDelete: Cascade)

  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  @@unique([cultId, creativeProfileId]) // can't join the same cult twice while active
  @@index([creativeProfileId])
}

model CultInvite {
  id     String            @id @default(cuid())
  status CultInviteStatus  @default(PENDING)

  cultId String
  cult   Cult   @relation(fields: [cultId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedByUser   User   @relation("CultInvitesSent", fields: [invitedByUserId], references: [id])

  invitedProfileId String
  invitedProfile   CreativeProfile @relation(fields: [invitedProfileId], references: [id], onDelete: Cascade)

  message String? // optional personal note from the leader

  respondedAt DateTime?
  expiresAt   DateTime? // optional — e.g. auto-expire after 7 days

  createdAt DateTime @default(now())

  @@index([invitedProfileId])
  @@index([cultId])
}

model Experience {
  id               String         @id @default(cuid())
  title            String
  employmentType   EmploymentType
  companyName      String?
  industry         String?
  startDate        DateTime
  endDate          DateTime?
  currentlyWorking Boolean        @default(false)
  description      String?
  skills           String[]

  creativeProfileId String
  creativeProfile   CreativeProfile @relation(fields: [creativeProfileId], references: [id], onDelete: Cascade)
}

model Education {
  id                String          @id @default(cuid())
  country           String
  school            String
  degree            Degree
  fieldOfStudy      String
  yearOfGraduation  String

  creativeProfileId String
  creativeProfile   CreativeProfile @relation(fields: [creativeProfileId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  joinAs    JoinAs
  createdAt DateTime @default(now())
  notifiedAt DateTime?
  inviteToken String? @unique
}
