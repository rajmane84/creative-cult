#!/bin/bash
cd "$(dirname "$0")/.."

# Create logs directory if it doesn't exist
mkdir -p .husky/logs

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}🚀 Starting pre-commit checks...${NC}"

# Track if any checks failed
FAILED=0

# 1. Check Prettier formatting (root level)
echo -e "\n${YELLOW}💄 Checking code formatting with Prettier...${NC}"
if ! bun run format:check > /dev/null 2>&1; then
    echo -e "${YELLOW}📝 Formatting issues found! Auto-fixing...${NC}"
    bun run format
    git add .
    echo -e "${GREEN}✅ Code formatted and staged automatically!${NC}"
else
    echo -e "${GREEN}✅ Code formatting looks good!${NC}"
fi

# 2. Check ESLint
echo -e "\n${YELLOW}🔍 Checking code quality with ESLint...${NC}"
if ! bun run lint > /dev/null 2>&1; then
    echo -e "${YELLOW}📝 ESLint issues found! Auto-fixing...${NC}"
    bun run lint:fix
    git add .
    echo -e "${GREEN}✅ ESLint issues fixed and staged automatically!${NC}"
else
    echo -e "${GREEN}✅ ESLint checks passed!${NC}"
fi

# 3. Check for frontend changes and run build
echo -e "\n${YELLOW}🔨 Checking for frontend changes...${NC}"
if git diff --cached --name-only | grep -q "^frontend/"; then
    echo -e "${YELLOW}📦 Frontend changes detected. Running build...${NC}"
    cd frontend
    if ! bun run build > ../.husky/logs/frontend-build.log 2>&1; then
        echo -e "\n${RED}❌ Frontend build failed! Check .husky/logs/frontend-build.log for details.${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✅ Frontend build passed!${NC}"
    fi
    cd ..
else
    echo -e "${GREEN}✅ No frontend changes detected. Skipping build.${NC}"
fi

# 4. Check for backend changes and run type check
echo -e "\n${YELLOW}🔍 Checking for backend changes...${NC}"
if git diff --cached --name-only | grep -q "^backend/"; then
    echo -e "${YELLOW}📝 Backend changes detected. Running type check...${NC}"
    cd backend
    if ! bun run typecheck > ../.husky/logs/backend-typecheck.log 2>&1; then
        echo -e "\n${RED}❌ Backend type check failed! Check .husky/logs/backend-typecheck.log for details.${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✅ Backend type check passed!${NC}"
    fi
    cd ..
else
    echo -e "${GREEN}✅ No backend changes detected. Skipping type check.${NC}"
fi

# Exit with error if any checks failed
if [ $FAILED -eq 1 ]; then
    echo -e "\n${RED}❌ Pre-commit checks failed! Please fix the errors before committing.${NC}"
    exit 1
fi

echo -e "\n${GREEN}🎉 All checks passed! Proceeding with commit...${NC}"